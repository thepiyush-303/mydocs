{
  "name": "mydocs",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime collaborative document editor boilerplate.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,blue \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
